@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix pset: <http://lv2plug.in/ns/ext/presets#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Each preset snapshots the full port list (host-independent).
# Port reference:
#   mode:       0=mono, 1=chord(tracks), 2=fixed, 3=fixed_chord
#   scale:      0=chromatic, 1=major, 2=minor
#   chord_type: 0=power 1=major 2=minor 3=sus2 4=sus4 5=dim 6=aug
#               7=maj7 8=min7 9=dom7 10=dim7 11=halfdim7
#               12=add9 13=dom9 14=min9

<https://github.com/richsio/autovocoder#preset/soundwave_c2>
    a pset:Preset ;
    rdfs:label "Soundwave (C2 / deep)" ;
    rdfs:comment "Authentic G1 Soundwave: fixed-root minor triad at C2. Scott Brownlee mixed Frank Welker's flat monotone delivery with chord-based vocoder carrier — this is that." ;
    lv2:appliesTo <https://github.com/richsio/autovocoder> ;
    lv2:port
        [ lv2:symbol "mode"           ; pset:value 3    ] ,
        [ lv2:symbol "fixed_note"     ; pset:value 36   ] ,
        [ lv2:symbol "scale"          ; pset:value 0    ] ,
        [ lv2:symbol "scale_root"     ; pset:value 0    ] ,
        [ lv2:symbol "mix"            ; pset:value 1.0  ] ,
        [ lv2:symbol "portamento"     ; pset:value 25.0 ] ,
        [ lv2:symbol "carrier_level"  ; pset:value 0.6  ] ,
        [ lv2:symbol "input_gain"     ; pset:value 9.0  ] ,
        [ lv2:symbol "output_gain"    ; pset:value 6.0  ] ,
        [ lv2:symbol "comp_on"        ; pset:value 1    ] ,
        [ lv2:symbol "comp_threshold" ; pset:value -18.0 ] ,
        [ lv2:symbol "chord_type"     ; pset:value 2    ] .

<https://github.com/richsio/autovocoder#preset/soundwave_c3>
    a pset:Preset ;
    rdfs:label "Soundwave (C3 / neutral)" ;
    rdfs:comment "Same Soundwave chord stack an octave up — more intelligible, less menacing." ;
    lv2:appliesTo <https://github.com/richsio/autovocoder> ;
    lv2:port
        [ lv2:symbol "mode"           ; pset:value 3    ] ,
        [ lv2:symbol "fixed_note"     ; pset:value 48   ] ,
        [ lv2:symbol "scale"          ; pset:value 0    ] ,
        [ lv2:symbol "scale_root"     ; pset:value 0    ] ,
        [ lv2:symbol "mix"            ; pset:value 1.0  ] ,
        [ lv2:symbol "portamento"     ; pset:value 25.0 ] ,
        [ lv2:symbol "carrier_level"  ; pset:value 0.6  ] ,
        [ lv2:symbol "input_gain"     ; pset:value 9.0  ] ,
        [ lv2:symbol "output_gain"    ; pset:value 6.0  ] ,
        [ lv2:symbol "comp_on"        ; pset:value 1    ] ,
        [ lv2:symbol "comp_threshold" ; pset:value -18.0 ] ,
        [ lv2:symbol "chord_type"     ; pset:value 2    ] .

<https://github.com/richsio/autovocoder#preset/intergalactic>
    a pset:Preset ;
    rdfs:label "Intergalactic" ;
    rdfs:comment "Beastie Boys vocoder-refrain vibe: fixed A2, snappy glide, bright carrier, hot output." ;
    lv2:appliesTo <https://github.com/richsio/autovocoder> ;
    lv2:port
        [ lv2:symbol "mode"           ; pset:value 2    ] ,
        [ lv2:symbol "fixed_note"     ; pset:value 45   ] ,
        [ lv2:symbol "scale"          ; pset:value 0    ] ,
        [ lv2:symbol "scale_root"     ; pset:value 0    ] ,
        [ lv2:symbol "mix"            ; pset:value 1.0  ] ,
        [ lv2:symbol "portamento"     ; pset:value 12.0 ] ,
        [ lv2:symbol "carrier_level"  ; pset:value 0.8  ] ,
        [ lv2:symbol "input_gain"     ; pset:value 12.0 ] ,
        [ lv2:symbol "output_gain"    ; pset:value 9.0  ] ,
        [ lv2:symbol "comp_on"        ; pset:value 1    ] ,
        [ lv2:symbol "comp_threshold" ; pset:value -20.0 ] ,
        [ lv2:symbol "chord_type"     ; pset:value 1    ] .

<https://github.com/richsio/autovocoder#preset/chromatic_robot>
    a pset:Preset ;
    rdfs:label "Chromatic Robot" ;
    rdfs:comment "Tracks the singer's pitch on a chromatic grid. Snappy portamento for a mechanical feel." ;
    lv2:appliesTo <https://github.com/richsio/autovocoder> ;
    lv2:port
        [ lv2:symbol "mode"           ; pset:value 0    ] ,
        [ lv2:symbol "fixed_note"     ; pset:value 48   ] ,
        [ lv2:symbol "scale"          ; pset:value 0    ] ,
        [ lv2:symbol "scale_root"     ; pset:value 0    ] ,
        [ lv2:symbol "mix"            ; pset:value 1.0  ] ,
        [ lv2:symbol "portamento"     ; pset:value 8.0  ] ,
        [ lv2:symbol "carrier_level"  ; pset:value 0.6  ] ,
        [ lv2:symbol "input_gain"     ; pset:value 9.0  ] ,
        [ lv2:symbol "output_gain"    ; pset:value 6.0  ] ,
        [ lv2:symbol "comp_on"        ; pset:value 1    ] ,
        [ lv2:symbol "comp_threshold" ; pset:value -18.0 ] ,
        [ lv2:symbol "chord_type"     ; pset:value 1    ] .

