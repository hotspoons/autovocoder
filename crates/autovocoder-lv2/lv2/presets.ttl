@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix pset: <http://lv2plug.in/ns/ext/presets#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Each preset snapshots the full control-port list (host-independent).
# Every preset sets every control port so that loading any preset gives a
# fully predictable state — no inheritance from whatever was loaded before.
# When a preset doesn't care about a given effect, it explicitly sets that
# effect off (or to its neutral default).
#
# Port reference:
#   mode:       0=mono, 1=chord(tracks), 2=fixed, 3=fixed_chord
#   scale:      0=chromatic, 1=major, 2=minor
#   chord_type: 0=power 1=major 2=minor 3=sus2 4=sus4 5=dim 6=aug
#               7=maj7 8=min7 9=dom7 10=dim7 11=halfdim7
#               12=add9 13=dom9 14=min9
#   pitch_algo: 0=YIN(classic) 1=YIN(FFT) 2=FFT(HPS)
#   trem_target: 0=output 1=carrier 2=both 3=modulator
#   drive_mode: 0=soft 1=tube 2=fuzz

<https://github.com/hotspoons/autovocoder#preset/soundwave_c2>
    a pset:Preset ;
    rdfs:label "Soundwave (C2 / deep)" ;
    rdfs:comment "Authentic G1 Soundwave: fixed-root minor triad at C2. Scott Brownlee mixed Frank Welker's flat monotone delivery with chord-based vocoder carrier — this is that." ;
    lv2:appliesTo <https://github.com/hotspoons/autovocoder> ;
    lv2:port
        [ lv2:symbol "mode"               ; pset:value 3    ] ,
        [ lv2:symbol "fixed_note"         ; pset:value 36   ] ,
        [ lv2:symbol "scale"              ; pset:value 0    ] ,
        [ lv2:symbol "scale_root"         ; pset:value 0    ] ,
        [ lv2:symbol "mix"                ; pset:value 1.0  ] ,
        [ lv2:symbol "portamento"         ; pset:value 25.0 ] ,
        [ lv2:symbol "carrier_level"      ; pset:value 0.6  ] ,
        [ lv2:symbol "input_gain"         ; pset:value 9.0  ] ,
        [ lv2:symbol "output_gain"        ; pset:value 6.0  ] ,
        [ lv2:symbol "comp_on"            ; pset:value 1    ] ,
        [ lv2:symbol "comp_threshold"     ; pset:value -18.0 ] ,
        [ lv2:symbol "chord_type"         ; pset:value 2    ] ,
        [ lv2:symbol "pitch_algo"         ; pset:value 1    ] ,
        [ lv2:symbol "carrier_chorus_on"  ; pset:value 0    ] ,
        [ lv2:symbol "output_chorus_on"   ; pset:value 0    ] ,
        [ lv2:symbol "chorus_rate"        ; pset:value 0.7  ] ,
        [ lv2:symbol "chorus_depth"       ; pset:value 0.5  ] ,
        [ lv2:symbol "chorus_mix"         ; pset:value 0.5  ] ,
        [ lv2:symbol "trem_on"            ; pset:value 0    ] ,
        [ lv2:symbol "trem_rate"          ; pset:value 5.0  ] ,
        [ lv2:symbol "trem_depth"         ; pset:value 0.7  ] ,
        [ lv2:symbol "trem_shape"         ; pset:value 0.0  ] ,
        [ lv2:symbol "trem_target"        ; pset:value 0    ] ,
        [ lv2:symbol "pre_drive_on"       ; pset:value 0    ] ,
        [ lv2:symbol "post_drive_on"      ; pset:value 0    ] ,
        [ lv2:symbol "drive_mode"         ; pset:value 1    ] ,
        [ lv2:symbol "drive_amount"       ; pset:value 0.5  ] ,
        [ lv2:symbol "crusher_on"         ; pset:value 0    ] ,
        [ lv2:symbol "crusher_bits"       ; pset:value 16   ] ,
        [ lv2:symbol "crusher_rate"       ; pset:value 1.0  ] ,
        [ lv2:symbol "sub_on"             ; pset:value 0    ] ,
        [ lv2:symbol "sub_level"          ; pset:value 0.5  ] .

