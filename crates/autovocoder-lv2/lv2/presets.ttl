<https://github.com/richsio/autovocoder#preset/power_chord_robot>
    a pset:Preset ;
    rdfs:label "Power Chord Robot (FixedChord, 5th)" ;
    rdfs:comment "Fixed power chord at A1. Rock-metal robot; no third means it fits over any tonality." ;
    lv2:appliesTo <https://github.com/richsio/autovocoder> ;
    lv2:port
        [ lv2:symbol "mode"           ; pset:value 3    ] ,
        [ lv2:symbol "fixed_note"     ; pset:value 33   ] ,
        [ lv2:symbol "scale"          ; pset:value 0    ] ,
        [ lv2:symbol "scale_root"     ; pset:value 0    ] ,
        [ lv2:symbol "mix"            ; pset:value 1.0  ] ,
        [ lv2:symbol "portamento"     ; pset:value 20.0 ] ,
        [ lv2:symbol "carrier_level"  ; pset:value 0.7  ] ,
        [ lv2:symbol "input_gain"     ; pset:value 12.0 ] ,
        [ lv2:symbol "output_gain"    ; pset:value 9.0  ] ,
        [ lv2:symbol "comp_on"        ; pset:value 1    ] ,
        [ lv2:symbol "comp_threshold" ; pset:value -18.0 ] ,
        [ lv2:symbol "chord_type"     ; pset:value 0    ] .

