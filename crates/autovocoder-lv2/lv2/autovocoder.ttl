@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix pset: <http://lv2plug.in/ns/ext/presets#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .

<https://github.com/richsio/autovocoder>
    a lv2:Plugin , lv2:SpectralPlugin ;
    doap:name "Autovocoder" ;
    doap:license <https://opensource.org/licenses/MIT> ;
    lv2:optionalFeature lv2:hardRTCapable ;
    rdfs:comment "Pitch-detect → scale-snap → carrier-synth → channel vocoder. Soundwave-style robotic voice made easy." ;

    lv2:port [
        a lv2:AudioPort , lv2:InputPort ;
        lv2:index 0 ;
        lv2:symbol "in" ;
        lv2:name "In"
    ] , [
        a lv2:AudioPort , lv2:OutputPort ;
        lv2:index 1 ;
        lv2:symbol "out" ;
        lv2:name "Out"
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 2 ;
        lv2:symbol "mode" ;
        lv2:name "Carrier Mode" ;
        lv2:portProperty lv2:enumeration , lv2:integer ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 3 ;
        lv2:scalePoint [ rdfs:label "Mono"             ; rdf:value 0 ] ;
        lv2:scalePoint [ rdfs:label "Chord (tracks)"   ; rdf:value 1 ] ;
        lv2:scalePoint [ rdfs:label "Fixed Note"       ; rdf:value 2 ] ;
        lv2:scalePoint [ rdfs:label "Fixed Chord"      ; rdf:value 3 ]
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 3 ;
        lv2:symbol "fixed_note" ;
        lv2:name "Fixed Note (MIDI)" ;
        lv2:portProperty lv2:integer ;
        lv2:default 48 ;
        lv2:minimum 24 ;
        lv2:maximum 84
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 4 ;
        lv2:symbol "scale" ;
        lv2:name "Scale" ;
        lv2:portProperty lv2:enumeration , lv2:integer ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 10 ;
        lv2:scalePoint [ rdfs:label "Chromatic"        ; rdf:value 0  ] ;
        lv2:scalePoint [ rdfs:label "Major"            ; rdf:value 1  ] ;
        lv2:scalePoint [ rdfs:label "Minor"            ; rdf:value 2  ] ;
        lv2:scalePoint [ rdfs:label "Dorian"           ; rdf:value 3  ] ;
        lv2:scalePoint [ rdfs:label "Phrygian"         ; rdf:value 4  ] ;
        lv2:scalePoint [ rdfs:label "Lydian"           ; rdf:value 5  ] ;
        lv2:scalePoint [ rdfs:label "Mixolydian"       ; rdf:value 6  ] ;
        lv2:scalePoint [ rdfs:label "Harmonic Minor"   ; rdf:value 7  ] ;
        lv2:scalePoint [ rdfs:label "Major Pentatonic" ; rdf:value 8  ] ;
        lv2:scalePoint [ rdfs:label "Minor Pentatonic" ; rdf:value 9  ] ;
        lv2:scalePoint [ rdfs:label "Blues"            ; rdf:value 10 ]
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 5 ;
        lv2:symbol "scale_root" ;
        lv2:name "Scale Root" ;
        lv2:portProperty lv2:enumeration , lv2:integer ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 11 ;
        lv2:scalePoint [ rdfs:label "C"  ; rdf:value 0  ] ;
        lv2:scalePoint [ rdfs:label "C#" ; rdf:value 1  ] ;
        lv2:scalePoint [ rdfs:label "D"  ; rdf:value 2  ] ;
        lv2:scalePoint [ rdfs:label "D#" ; rdf:value 3  ] ;
        lv2:scalePoint [ rdfs:label "E"  ; rdf:value 4  ] ;
        lv2:scalePoint [ rdfs:label "F"  ; rdf:value 5  ] ;
        lv2:scalePoint [ rdfs:label "F#" ; rdf:value 6  ] ;
        lv2:scalePoint [ rdfs:label "G"  ; rdf:value 7  ] ;
        lv2:scalePoint [ rdfs:label "G#" ; rdf:value 8  ] ;
        lv2:scalePoint [ rdfs:label "A"  ; rdf:value 9  ] ;
        lv2:scalePoint [ rdfs:label "A#" ; rdf:value 10 ] ;
        lv2:scalePoint [ rdfs:label "B"  ; rdf:value 11 ]
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 6 ;
        lv2:symbol "mix" ;
        lv2:name "Dry/Wet" ;
        lv2:default 1.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 7 ;
        lv2:symbol "portamento" ;
        lv2:name "Portamento" ;
        lv2:default 25.0 ;
        lv2:minimum 1.0 ;
        lv2:maximum 500.0 ;
        units:unit units:ms
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 8 ;
        lv2:symbol "carrier_level" ;
        lv2:name "Carrier Level" ;
        lv2:default 0.6 ;
        lv2:minimum 0.0 ;
        lv2:maximum 2.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 9 ;
        lv2:symbol "input_gain" ;
        lv2:name "Input Gain" ;
        lv2:default 9.0 ;
        lv2:minimum -20.0 ;
        lv2:maximum 60.0 ;
        units:unit units:db
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 10 ;
        lv2:symbol "output_gain" ;
        lv2:name "Output Gain" ;
        lv2:default 6.0 ;
        lv2:minimum -20.0 ;
        lv2:maximum 60.0 ;
        units:unit units:db
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 11 ;
        lv2:symbol "comp_on" ;
        lv2:name "Compressor" ;
        lv2:portProperty lv2:toggled , lv2:integer ;
        lv2:default 1 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 12 ;
        lv2:symbol "comp_threshold" ;
        lv2:name "Compressor Threshold" ;
        lv2:default -18.0 ;
        lv2:minimum -40.0 ;
        lv2:maximum 0.0 ;
        units:unit units:db
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 13 ;
        lv2:symbol "chord_type" ;
        lv2:name "Chord Type" ;
        lv2:portProperty lv2:enumeration , lv2:integer ;
        lv2:default 1 ;
        lv2:minimum 0 ;
        lv2:maximum 14 ;
        lv2:scalePoint [ rdfs:label "Power (5)"       ; rdf:value 0  ] ;
        lv2:scalePoint [ rdfs:label "Major"           ; rdf:value 1  ] ;
        lv2:scalePoint [ rdfs:label "Minor"           ; rdf:value 2  ] ;
        lv2:scalePoint [ rdfs:label "Sus2"            ; rdf:value 3  ] ;
        lv2:scalePoint [ rdfs:label "Sus4"            ; rdf:value 4  ] ;
        lv2:scalePoint [ rdfs:label "Diminished"      ; rdf:value 5  ] ;
        lv2:scalePoint [ rdfs:label "Augmented"       ; rdf:value 6  ] ;
        lv2:scalePoint [ rdfs:label "Major 7"         ; rdf:value 7  ] ;
        lv2:scalePoint [ rdfs:label "Minor 7"         ; rdf:value 8  ] ;
        lv2:scalePoint [ rdfs:label "Dominant 7"      ; rdf:value 9  ] ;
        lv2:scalePoint [ rdfs:label "Diminished 7"    ; rdf:value 10 ] ;
        lv2:scalePoint [ rdfs:label "Half-Diminished" ; rdf:value 11 ] ;
        lv2:scalePoint [ rdfs:label "Add 9"           ; rdf:value 12 ] ;
        lv2:scalePoint [ rdfs:label "Dominant 9"      ; rdf:value 13 ] ;
        lv2:scalePoint [ rdfs:label "Minor 9"         ; rdf:value 14 ]
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 14 ;
        lv2:symbol "pitch_algo" ;
        lv2:name "Pitch Detector" ;
        lv2:portProperty lv2:enumeration , lv2:integer ;
        lv2:default 1 ;
        lv2:minimum 0 ;
        lv2:maximum 2 ;
        lv2:scalePoint [ rdfs:label "YIN (classic)"   ; rdf:value 0 ] ;
        lv2:scalePoint [ rdfs:label "YIN (FFT)"       ; rdf:value 1 ] ;
        lv2:scalePoint [ rdfs:label "FFT (HPS)"       ; rdf:value 2 ]
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 15 ;
        lv2:symbol "carrier_chorus_on" ;
        lv2:name "Chorus on Carrier" ;
        lv2:portProperty lv2:toggled , lv2:integer ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 16 ;
        lv2:symbol "output_chorus_on" ;
        lv2:name "Chorus on Output" ;
        lv2:portProperty lv2:toggled , lv2:integer ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 17 ;
        lv2:symbol "chorus_rate" ;
        lv2:name "Chorus Rate" ;
        lv2:default 0.7 ;
        lv2:minimum 0.05 ;
        lv2:maximum 5.0 ;
        units:unit units:hz
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 18 ;
        lv2:symbol "chorus_depth" ;
        lv2:name "Chorus Depth" ;
        lv2:default 0.5 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 19 ;
        lv2:symbol "chorus_mix" ;
        lv2:name "Chorus Mix" ;
        lv2:default 0.5 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 20 ;
        lv2:symbol "trem_on" ;
        lv2:name "Tremolo" ;
        lv2:portProperty lv2:toggled , lv2:integer ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 21 ;
        lv2:symbol "trem_rate" ;
        lv2:name "Tremolo Rate" ;
        lv2:default 5.0 ;
        lv2:minimum 0.1 ;
        lv2:maximum 20.0 ;
        units:unit units:hz
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 22 ;
        lv2:symbol "trem_depth" ;
        lv2:name "Tremolo Depth" ;
        lv2:default 0.7 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 23 ;
        lv2:symbol "trem_shape" ;
        lv2:name "Tremolo Shape (Sine→Square)" ;
        lv2:default 0.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 24 ;
        lv2:symbol "trem_target" ;
        lv2:name "Mod LFO Target" ;
        lv2:portProperty lv2:enumeration , lv2:integer ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 3 ;
        lv2:scalePoint [ rdfs:label "Amplitude (tremolo)" ; rdf:value 0 ] ;
        lv2:scalePoint [ rdfs:label "Pitch (vibrato)"     ; rdf:value 1 ] ;
        lv2:scalePoint [ rdfs:label "Dry/Wet"             ; rdf:value 2 ] ;
        lv2:scalePoint [ rdfs:label "Carrier Level"       ; rdf:value 3 ]
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 25 ;
        lv2:symbol "pre_drive_on" ;
        lv2:name "Drive on Modulator (pre-vocoder)" ;
        lv2:portProperty lv2:toggled , lv2:integer ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 26 ;
        lv2:symbol "post_drive_on" ;
        lv2:name "Drive on Output (post)" ;
        lv2:portProperty lv2:toggled , lv2:integer ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 27 ;
        lv2:symbol "drive_mode" ;
        lv2:name "Drive Mode" ;
        lv2:portProperty lv2:enumeration , lv2:integer ;
        lv2:default 1 ;
        lv2:minimum 0 ;
        lv2:maximum 2 ;
        lv2:scalePoint [ rdfs:label "Tube" ; rdf:value 0 ] ;
        lv2:scalePoint [ rdfs:label "Tape" ; rdf:value 1 ] ;
        lv2:scalePoint [ rdfs:label "Fuzz" ; rdf:value 2 ]
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 28 ;
        lv2:symbol "drive_amount" ;
        lv2:name "Drive Amount" ;
        lv2:default 0.5 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 29 ;
        lv2:symbol "crusher_on" ;
        lv2:name "Bit Crusher" ;
        lv2:portProperty lv2:toggled , lv2:integer ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 30 ;
        lv2:symbol "crusher_bits" ;
        lv2:name "Crusher Bit Depth" ;
        lv2:portProperty lv2:integer ;
        lv2:default 16 ;
        lv2:minimum 1 ;
        lv2:maximum 16
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 31 ;
        lv2:symbol "crusher_rate" ;
        lv2:name "Crusher Rate" ;
        lv2:default 1.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 32 ;
        lv2:symbol "sub_on" ;
        lv2:name "Sub Oscillator" ;
        lv2:portProperty lv2:toggled , lv2:integer ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 33 ;
        lv2:symbol "sub_level" ;
        lv2:name "Sub Level" ;
        lv2:default 0.5 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0
    ] .
