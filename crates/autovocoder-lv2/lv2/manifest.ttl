@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix pset: <http://lv2plug.in/ns/ext/presets#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://github.com/hotspoons/autovocoder>
    a lv2:Plugin ;
    lv2:binary <libautovocoder_lv2.so> ;
    rdfs:seeAlso <autovocoder.ttl> .

# Register every preset in presets.ttl so hosts discover them.
# Each entry says "here is a Preset that applies to our plugin, its
# details are in presets.ttl."

<https://github.com/hotspoons/autovocoder#preset/soundwave_c2>
    a pset:Preset ;
    lv2:appliesTo <https://github.com/hotspoons/autovocoder> ;
    rdfs:seeAlso <presets.ttl> .

